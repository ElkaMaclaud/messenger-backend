# Скопируйте в .env и заполните значениями.

# HTTP
PORT=3001
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5444
DB_USER=postgres
DB_PASSWORD=qwerty
DB_NAME=messenger_db

# Auth — обязательно задать свой секрет в проде
JWT_SECRET=super_secret_key

# Web Push (VAPID). Сгенерировать: npx web-push generate-vapid-keys
# Push отключён, пока VAPID_PUBLIC_KEY равен test-public-key
VAPID_PUBLIC_KEY=test-public-key
VAPID_PRIVATE_KEY=test-private-key
VAPID_SUBJECT=mailto:example@yourdomain.org

# Docker Compose
COMPOSE_PROJECT_NAME=messenger_pet
PG_PORT=5444
